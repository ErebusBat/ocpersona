#!/bin/sh

set -eu

SELF_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
SOURCE_ROOT=$(CDPATH= cd -- "$SELF_DIR/.." && pwd)
SOURCE_SHIM_DIR=${OCP_SHIM_DIR:-"$SOURCE_ROOT/shims"}

BOOTSTRAP_CONFIG_DIR=${OCP_CONFIG_DIR:-"$HOME/.config/ocpersona"}
BOOTSTRAP_CONFIG_FILE=$BOOTSTRAP_CONFIG_DIR/config.sh
if [ -f "$BOOTSTRAP_CONFIG_FILE" ]; then
  set -a
  # shellcheck source=/dev/null
  . "$BOOTSTRAP_CONFIG_FILE"
  set +a
fi

DEFAULT_CONFIG_DIR=${OCP_CONFIG_DIR:-"$HOME/.config/ocpersona"}
DEFAULT_OCP_PATH=${OCP_PATH:-"$SOURCE_ROOT"}
DEFAULT_PROFILES_DIR=$DEFAULT_CONFIG_DIR/profiles

refresh_default_paths() {
  DEFAULT_CONFIG_DIR=${OCP_CONFIG_DIR:-"$HOME/.config/ocpersona"}
  DEFAULT_OCP_PATH=${OCP_PATH:-"$SOURCE_ROOT"}
  DEFAULT_PROFILES_DIR=$DEFAULT_CONFIG_DIR/profiles
}

usage() {
  cat <<EOF
Usage: ocpersona <command> [options]

Commands:
  list                             List available profiles
  exec <profile> -- <command...>   Run a command inside a profile
  activate [--local] <profile>     Print shell code to activate a profile
                                    --local also writes .ocpersona in the repo root
  activate --unset                 Remove OCP_PROFILE from the repo .ocpersona
  deactivate                       Print shell code to deactivate the profile
  link [--all] <profile> [app] [flags]
                                   Link profile app paths to real machine paths
  clone <source> <target>          Clone one ocpersona profile into another
  clone-default [profile]          Clone ~/.config/opencode into a profile
  purge [profile]                  Remove a profile's config, data, state, and cache
  doctor                           Show current environment and integration info
  dump-env [profile]               Print environment variables for a profile
  install [file]                   Install zsh init into a shell file
  install-starship [file]          Install Starship config for OCP_PROFILE
  init [zsh|bash|sh]               Print shell init code
  __shim_opencode [args...]        Internal shim entrypoint
  __run_real_opencode [args...]    Internal helper
  help                             Show this help
EOF
}

fail() {
  printf '%s\n' "$*" >&2
  exit 1
}

ensure_profile_name() {
  case "$1" in
    "") fail "Profile name is required" ;;
    *[!A-Za-z0-9._-]*)
      fail "Invalid profile name: $1"
      ;;
  esac
}

ensure_app_name() {
  case "$1" in
    "") fail "App name is required" ;;
    *[!A-Za-z0-9._-]*)
      fail "Invalid app name: $1"
      ;;
  esac
}

profile_root_for() {
  printf '%s/%s\n' "$DEFAULT_PROFILES_DIR" "$1"
}

profile_file_for() {
  printf '%s/ocpersona.sh\n' "$(profile_root_for "$1")"
}

profile_config_home_for() {
  printf '%s/config\n' "$(profile_root_for "$1")"
}

profile_data_home_for() {
  printf '%s/data\n' "$(profile_root_for "$1")"
}

profile_state_home_for() {
  printf '%s/state\n' "$(profile_root_for "$1")"
}

profile_cache_home_for() {
  printf '%s/.cache/ocpersona/%s\n' "$HOME" "$1"
}

real_config_home_for() {
  printf '%s\n' "${OCP_REAL_CONFIG_HOME:-$HOME/.config}"
}

real_data_home_for() {
  printf '%s\n' "${OCP_REAL_DATA_HOME:-$HOME/.local/share}"
}

real_state_home_for() {
  printf '%s\n' "${OCP_REAL_STATE_HOME:-$HOME/.local/state}"
}

real_cache_home_for() {
  printf '%s\n' "${OCP_REAL_CACHE_HOME:-$HOME/.cache}"
}

dump_var() {
  eval "val=\${$1:-}"
  printf 'export %s=' "$1"
  printf "'%s'\n" "$(printf '%s\n' "$val" | sed "s/'/'\\\\''/g")"
}

source_root_for_scope() {
  scope_name=$1
  case "$scope_name" in
    config) real_config_home_for ;;
    data) real_data_home_for ;;
    state) real_state_home_for ;;
    cache) real_cache_home_for ;;
    *) fail "Unknown scope: $scope_name" ;;
  esac
}

target_root_for_scope() {
  profile_name=$1
  scope_name=$2
  case "$scope_name" in
    config) profile_config_home_for "$profile_name" ;;
    data) profile_data_home_for "$profile_name" ;;
    state) profile_state_home_for "$profile_name" ;;
    cache) profile_cache_home_for "$profile_name" ;;
    *) fail "Unknown scope: $scope_name" ;;
  esac
}

default_link_apps() {
  printf '%s\n' "${OCP_DEFAULT_LINK_APPS:-gh vim nvim}"
}

link_default_apps_for_profile() {
  profile_name=$1

  for app_name in $(default_link_apps); do
    ensure_app_name "$app_name"
    if [ "$app_name" = "opencode" ]; then
      printf 'Skipping reserved default link app: %s\n' "$app_name"
      continue
    fi

    linked_any=0
    for scope_name in config data state cache; do
      case "$scope_name" in
        config) source_root=$(real_config_home_for) ;;
        data) source_root=$(real_data_home_for) ;;
        state) source_root=$(real_state_home_for) ;;
        cache) source_root=$(real_cache_home_for) ;;
      esac

      if [ -e "$source_root/$app_name" ]; then
        link_scope_path "$profile_name" "$app_name" "$scope_name" 0
        linked_any=1
      fi
    done

    if [ "$linked_any" = "0" ]; then
      printf 'Skipped default link app %s: no source paths found\n' "$app_name"
    fi
  done
}

managed_config_file() {
  printf '%s/config.sh\n' "$DEFAULT_CONFIG_DIR"
}

default_starship_config() {
  if [ -n "${STARSHIP_CONFIG:-}" ]; then
    printf '%s\n' "$STARSHIP_CONFIG"
    return 0
  fi

  printf '%s/.config/starship.toml\n' "$HOME"
}

runtime_shim_dir() {
  printf '%s/shims\n' "$DEFAULT_OCP_PATH"
}

remove_managed_block() {
  target_file=$1
  start_marker=$2
  end_marker=$3

  if grep -Fq "$start_marker" "$target_file"; then
    tmp_file=$target_file.ocpersona.tmp
    awk -v start="$start_marker" -v end="$end_marker" '
      $0 == start { skipping=1; next }
      $0 == end { skipping=0; next }
      !skipping { print }
    ' "$target_file" > "$tmp_file"
    mv "$tmp_file" "$target_file"
  fi
}

append_managed_block() {
  target_file=$1
  block_content=$2

  [ -s "$target_file" ] && printf '\n' >> "$target_file"
  printf '%s\n' "$block_content" >> "$target_file"
}

emit_prepend_path_snippet() {
  shim_dir=$1
  cat <<EOF
path_without_shim=
old_ifs=\$IFS
IFS=:
for path_dir in \$PATH; do
  IFS=\$old_ifs
  [ -n "\$path_dir" ] || path_dir=.
  [ "\$path_dir" = "$shim_dir" ] && continue
  if [ -n "\${path_without_shim:-}" ]; then
    path_without_shim=\${path_without_shim}:\$path_dir
  else
    path_without_shim=\$path_dir
  fi
  IFS=:
done
IFS=\$old_ifs
if [ -n "\${path_without_shim:-}" ]; then
  export PATH="$shim_dir:\$path_without_shim"
else
  export PATH="$shim_dir"
fi
unset path_without_shim
unset old_ifs
unset path_dir
EOF
}

default_shell_rc() {
  if [ -n "${ZSHRC:-}" ]; then
    printf '%s\n' "$ZSHRC"
    return 0
  fi

  if [ -n "${ZDOTDIR:-}" ]; then
    printf '%s/.zshrc\n' "$ZDOTDIR"
    return 0
  fi

  printf '%s/.zshrc\n' "$HOME"
}

resolve_real_command() {
  command_name=$1
  old_ifs=${IFS}
  IFS=:
  for path_dir in $PATH; do
    IFS=${old_ifs}
    [ -n "$path_dir" ] || path_dir=.
    [ "$path_dir" = "$SOURCE_SHIM_DIR" ] && continue
    [ "$path_dir" = "$(runtime_shim_dir)" ] && continue
    candidate=$path_dir/$command_name
    if [ -x "$candidate" ] && [ ! -d "$candidate" ]; then
      printf '%s\n' "$candidate"
      return 0
    fi
    IFS=:
  done
  IFS=${old_ifs}
  return 1
}

resolve_realpath() {
  target=$1
  python3 - "$target" <<'PY'
import os
import sys
print(os.path.realpath(sys.argv[1]))
PY
}

default_oc_bin() {
  resolved=$(resolve_real_command opencode) || fail "Could not locate real opencode on PATH"
  resolve_realpath "$resolved"
}

git_repo_root_for_pwd() {
  /usr/bin/env git rev-parse --show-toplevel 2>/dev/null || return 1
}

emit_ocp_env_from_marker() {
  marker_file=$1
  MARKER_FILE="$marker_file" /bin/sh <<'EOF'
set -eu
set -a
. "$MARKER_FILE"
set +a
env | /usr/bin/env grep '^OCP_' || true
EOF
}

apply_ocp_env_lines() {
  env_lines=$1
  [ -n "$env_lines" ] || return 0

  while IFS= read -r line; do
    [ -n "$line" ] || continue
    case "$line" in
      OCP_*=*) export "$line" ;;
    esac
  done <<EOF
$env_lines
EOF
}

update_marker_file() {
  marker_file=$1
  profile_name=$2
  ensure_profile_name "$profile_name"
  profile_line="export OCP_PROFILE=$profile_name"

  if [ ! -f "$marker_file" ]; then
    printf '%s\n' "$profile_line" > "$marker_file"
    return 0
  fi

  if grep -Fq "export OCP_PROFILE=" "$marker_file"; then
    tmp_file=$marker_file.ocpersona.tmp
    sed "s|^export OCP_PROFILE=.*$|$profile_line|" "$marker_file" > "$tmp_file"
    mv "$tmp_file" "$marker_file"
    return 0
  fi

  printf '%s\n' "$profile_line" >> "$marker_file"
}

remove_marker_profile_line() {
  marker_file=$1

  [ -f "$marker_file" ] || return 0

  if ! grep -Fq "export OCP_PROFILE=" "$marker_file"; then
    return 0
  fi

  tmp_file=$marker_file.ocpersona.tmp
  grep -v "^export OCP_PROFILE=" "$marker_file" > "$tmp_file" || true
  mv "$tmp_file" "$marker_file"

  if [ ! -s "$marker_file" ]; then
    rm -f "$marker_file"
  fi
}

auto_detect_profile_if_unset() {
  [ -n "${OCP_PROFILE:-}" ] && return 0

  repo_root=$(git_repo_root_for_pwd) || return 0
  marker_file=$repo_root/.ocpersona
  [ -f "$marker_file" ] || return 0

  marker_env=$(emit_ocp_env_from_marker "$marker_file") || fail "Failed to source repo marker: $marker_file"
  apply_ocp_env_lines "$marker_env"

  [ -n "${OCP_PROFILE:-}" ] || fail "Repo marker must export OCP_PROFILE: $marker_file"
  ensure_profile_name "$OCP_PROFILE"

  refresh_default_paths
}

load_profile() {
  profile_name=$1
  ensure_profile_name "$profile_name"
  profile_file=$(profile_file_for "$profile_name")
  [ -f "$profile_file" ] || fail "Profile file not found: $profile_file"

  export OCP_PROFILE=$profile_name
  export OCP_PROFILE_FILE=$profile_file
  export OCP_PATH=${OCP_PATH:-$DEFAULT_OCP_PATH}
  export OCP_SHIM_DIR=${OCP_SHIM_DIR:-$SOURCE_SHIM_DIR}
  export OCP_CONFIG_DIR=$DEFAULT_CONFIG_DIR

  set -a
  # shellcheck source=/dev/null
  . "$profile_file"
  set +a

  : "${XDG_CONFIG_HOME:=$(profile_config_home_for "$OCP_PROFILE")}"
  : "${XDG_DATA_HOME:=$(profile_data_home_for "$OCP_PROFILE")}"
  : "${XDG_STATE_HOME:=$(profile_state_home_for "$OCP_PROFILE")}"
  : "${XDG_CACHE_HOME:=$HOME/.cache/ocpersona/$OCP_PROFILE}"

  export XDG_CONFIG_HOME
  export XDG_DATA_HOME
  export XDG_STATE_HOME
  export XDG_CACHE_HOME

  case ":$PATH:" in
    *":$OCP_SHIM_DIR:"*) ;;
    *) PATH=$OCP_SHIM_DIR:$PATH ;;
  esac
  export PATH
  export OCP_ACTIVE=1
}

cmd_exec() {
  [ $# -ge 3 ] || fail "Usage: ocpersona exec <profile> -- <command...>"
  profile_name=$1
  shift
  [ "$1" = "--" ] || fail "Usage: ocpersona exec <profile> -- <command...>"
  shift
  [ $# -gt 0 ] || fail "A command is required"

  load_profile "$profile_name"
  exec "$@"
}

cmd_list() {
  [ $# -eq 0 ] || fail "Usage: ocpersona list"

  [ -d "$DEFAULT_PROFILES_DIR" ] || return 0

  profile_entries=
  for profile_dir in "$DEFAULT_PROFILES_DIR"/*; do
    [ -d "$profile_dir" ] || continue
    profile_name=$(basename -- "$profile_dir")
    ensure_profile_name "$profile_name"
    [ -f "$(profile_file_for "$profile_name")" ] || continue
    profile_entries="${profile_entries}${profile_name}\n"
  done

  [ -n "$profile_entries" ] || return 0

  printf '%b' "$profile_entries" | /usr/bin/env sort
}

list_profile_names() {
  [ -d "$DEFAULT_PROFILES_DIR" ] || return 0

  profile_entries=
  for profile_dir in "$DEFAULT_PROFILES_DIR"/*; do
    [ -d "$profile_dir" ] || continue
    profile_name=$(basename -- "$profile_dir")
    ensure_profile_name "$profile_name"
    [ -f "$(profile_file_for "$profile_name")" ] || continue
    profile_entries="${profile_entries}${profile_name}\n"
  done

  [ -n "$profile_entries" ] || return 0
  printf '%b' "$profile_entries" | /usr/bin/env sort
}

cmd_activate() {
  do_local=0
  do_unset=0
  profile_name=

  while [ $# -gt 0 ]; do
    case "$1" in
      --local)
        do_local=1
        ;;
      --unset)
        do_unset=1
        ;;
      --*)
        fail "Unknown flag: $1"
        ;;
      *)
        if [ -n "$profile_name" ]; then
          fail "Unexpected argument: $1"
        fi
        profile_name=$1
        ;;
    esac
    shift
  done

  if [ "$do_local" = "1" ] && [ "$do_unset" = "1" ]; then
    fail "--local and --unset are mutually exclusive"
  fi

  if [ "$do_unset" = "1" ]; then
    [ -z "$profile_name" ] || fail "--unset does not accept a profile name"
    repo_root=$(git_repo_root_for_pwd) || repo_root=${OCP_LOCAL_DIR:-$(pwd)}
    marker_file=$repo_root/.ocpersona
    remove_marker_profile_line "$marker_file"
    printf 'Removed OCP_PROFILE from %s\n' "$marker_file" >&2
    return 0
  fi

  : "${profile_name:=${_pre_autodetect_profile:-}}"
  [ -n "$profile_name" ] || fail "Usage: ocpersona activate [--local] <profile> or ocpersona activate --unset"
  ensure_profile_name "$profile_name"
  profile_file=$(profile_file_for "$profile_name")
  [ -f "$profile_file" ] || fail "Profile file not found: $profile_file"

  if [ "$do_local" = "1" ]; then
    repo_root=$(git_repo_root_for_pwd) || repo_root=${OCP_LOCAL_DIR:-$(pwd)}
    marker_file=$repo_root/.ocpersona
    update_marker_file "$marker_file" "$profile_name"
    printf 'Set OCP_PROFILE=%s in %s\n' "$profile_name" "$marker_file" >&2
  fi

  cat <<EOF
export OCP_PROFILE='$profile_name'
export OCP_PROFILE_FILE='$profile_file'
export OCP_CONFIG_DIR='${DEFAULT_CONFIG_DIR}'
export OCP_PATH='${DEFAULT_OCP_PATH}'
export OCP_SHIM_DIR='$(runtime_shim_dir)'
$(emit_prepend_path_snippet "$(runtime_shim_dir)")
if command -v rehash >/dev/null 2>&1; then
  rehash
elif command -v hash >/dev/null 2>&1; then
  hash -r 2>/dev/null || true
fi
set -a
. '$profile_file'
set +a
: "\${XDG_CONFIG_HOME:=$(profile_config_home_for "$profile_name")}"
: "\${XDG_DATA_HOME:=$(profile_data_home_for "$profile_name")}"
: "\${XDG_STATE_HOME:=$(profile_state_home_for "$profile_name")}"
: "\${XDG_CACHE_HOME:=$HOME/.cache/ocpersona/$profile_name}"
export XDG_CONFIG_HOME
export XDG_DATA_HOME
export XDG_STATE_HOME
export XDG_CACHE_HOME
export OCP_ACTIVE=1
if command -v rehash >/dev/null 2>&1; then
  rehash
elif command -v hash >/dev/null 2>&1; then
  hash -r 2>/dev/null || true
fi
EOF
}

cmd_deactivate() {
  cat <<EOF
unset OCP_PROFILE
unset OCP_PROFILE_FILE
unset OCP_ACTIVE
unset XDG_CONFIG_HOME
unset XDG_DATA_HOME
unset XDG_STATE_HOME
unset XDG_CACHE_HOME
EOF
}

cmd_clone_default() {
  [ $# -le 1 ] || fail "Usage: ocpersona clone-default [profile]"

  profile_name=${1:-${OCP_PROFILE:-default}}
  ensure_profile_name "$profile_name"

  source_config_home=${XDG_CONFIG_HOME:-$HOME/.config}
  source_config_dir=$source_config_home/opencode
  [ -d "$source_config_dir" ] || fail "OpenCode config directory not found: $source_config_dir"
  source_data_home=${XDG_DATA_HOME:-$HOME/.local/share}
  source_data_dir=$source_data_home/opencode
  source_state_home=${XDG_STATE_HOME:-$HOME/.local/state}
  source_state_dir=$source_state_home/opencode

  profile_root=$(profile_root_for "$profile_name")
  profile_file=$(profile_file_for "$profile_name")
  profile_config_home=$(profile_config_home_for "$profile_name")
  target_config_dir=$profile_config_home/opencode
  profile_data_home=$(profile_data_home_for "$profile_name")
  target_data_dir=$profile_data_home/opencode
  profile_state_home=$(profile_state_home_for "$profile_name")
  target_state_dir=$profile_state_home/opencode

  [ ! -e "$profile_file" ] || fail "Profile file already exists: $profile_file"
  [ ! -e "$profile_root" ] || fail "Profile directory already exists: $profile_root"

  mkdir -p "$DEFAULT_PROFILES_DIR"
  mkdir -p "$profile_root" "$profile_config_home"
  cp -R "$source_config_dir" "$target_config_dir"
  if [ -d "$source_data_dir" ]; then
    mkdir -p "$profile_data_home"
    cp -R "$source_data_dir" "$target_data_dir"
  fi
  if [ -d "$source_state_dir" ]; then
    mkdir -p "$profile_state_home"
    cp -R "$source_state_dir" "$target_state_dir"
  fi

  cat > "$profile_file" <<EOF
# Generated by ocpersona clone-default.
profile_dir=\${OCP_PROFILE_FILE%/*}
XDG_CONFIG_HOME="\${profile_dir}/config"
XDG_DATA_HOME="\${profile_dir}/data"
XDG_STATE_HOME="\${profile_dir}/state"
EOF

  printf 'Cloned %s into profile %s\n' "$source_config_dir" "$profile_name"
  if [ -d "$source_data_dir" ]; then
    printf 'Cloned %s into %s\n' "$source_data_dir" "$target_data_dir"
  fi
  if [ -d "$source_state_dir" ]; then
    printf 'Cloned %s into %s\n' "$source_state_dir" "$target_state_dir"
  fi

  link_default_apps_for_profile "$profile_name"
}

cmd_clone() {
  [ $# -eq 2 ] || fail "Usage: ocpersona clone <source> <target>"

  source_profile=$1
  target_profile=$2
  ensure_profile_name "$source_profile"
  ensure_profile_name "$target_profile"
  [ "$source_profile" != "$target_profile" ] || fail "Source and target profiles must differ"

  source_root=$(profile_root_for "$source_profile")
  source_file=$(profile_file_for "$source_profile")
  source_cache_home=$(profile_cache_home_for "$source_profile")
  target_root=$(profile_root_for "$target_profile")
  target_cache_home=$(profile_cache_home_for "$target_profile")

  [ -f "$source_file" ] || fail "Source profile file not found: $source_file"
  [ -d "$source_root" ] || fail "Source profile directory not found: $source_root"
  [ ! -e "$target_root" ] || fail "Target profile directory already exists: $target_root"
  [ ! -e "$target_cache_home" ] || fail "Target profile cache directory already exists: $target_cache_home"

  mkdir -p "$DEFAULT_PROFILES_DIR"
  cp -R "$source_root" "$target_root"
  if [ -d "$source_cache_home" ]; then
    mkdir -p "$(dirname -- "$target_cache_home")"
    cp -R "$source_cache_home" "$target_cache_home"
  fi

  printf 'Cloned profile %s into %s\n' "$source_profile" "$target_profile"
  if [ -d "$source_cache_home" ]; then
    printf 'Cloned %s into %s\n' "$source_cache_home" "$target_cache_home"
  fi
}

link_scope_path() {
  profile_name=$1
  app_name=$2
  scope_name=$3
  force_link=$4

  case "$scope_name" in
    config|data|state|cache) ;;
    *) fail "Unknown scope: $scope_name" ;;
  esac

  source_root=$(source_root_for_scope "$scope_name")
  target_root=$(target_root_for_scope "$profile_name" "$scope_name")

  source_path=$source_root/$app_name
  target_path=$target_root/$app_name

  [ -e "$source_path" ] || fail "Source path not found for $scope_name: $source_path"

  mkdir -p "$target_root"

  if [ "$force_link" = "1" ]; then
    if [ -e "$target_path" ] || [ -L "$target_path" ]; then
      rm -rf "$target_path"
    fi
    ln -s "$source_path" "$target_path"
    printf 'Linked %s: %s -> %s\n' "$scope_name" "$target_path" "$source_path"
    return 0
  fi

  if [ -L "$target_path" ]; then
    source_real=$(resolve_realpath "$source_path")
    target_real=$(resolve_realpath "$target_path")
    if [ "$source_real" = "$target_real" ]; then
      printf 'Already linked %s: %s -> %s\n' "$scope_name" "$target_path" "$source_path"
      return 0
    fi
    fail "Target already links to a different path for $scope_name: $target_path"
  fi

  if [ -e "$target_path" ]; then
    fail "Target already exists for $scope_name: $target_path"
  fi

  ln -s "$source_path" "$target_path"
  printf 'Linked %s: %s -> %s\n' "$scope_name" "$target_path" "$source_path"
}

cmd_link() {
  [ $# -gt 0 ] || fail "Usage: ocpersona link [--all] <profile> [app] [--no-config] [--no-data] [--no-state] [--no-cache] [--force]"

  all_profiles=0
  do_config=1
  do_data=1
  do_state=1
  do_cache=1
  force_link=0
  positional_count=0
  pos1=
  pos2=

  while [ $# -gt 0 ]; do
    case "$1" in
      --all)
        all_profiles=1
        ;;
      --no-config)
        do_config=0
        ;;
      --no-data)
        do_data=0
        ;;
      --no-state)
        do_state=0
        ;;
      --no-cache)
        do_cache=0
        ;;
      --force)
        force_link=1
        ;;
      --*)
        fail "Unknown flag: $1"
        ;;
      *)
        positional_count=$((positional_count + 1))
        case "$positional_count" in
          1)
            pos1=$1
            ;;
          2)
            pos2=$1
            ;;
          *)
            fail "Too many positional arguments for link"
            ;;
        esac
        ;;
    esac
    shift
  done

  if [ "$do_config" = "0" ] && [ "$do_data" = "0" ] && [ "$do_state" = "0" ] && [ "$do_cache" = "0" ]; then
    fail "At least one scope must be enabled"
  fi

  if [ "$all_profiles" = "1" ]; then
    [ "$positional_count" -le 1 ] || fail "Usage: ocpersona link --all [app] [--no-config] [--no-data] [--no-state] [--no-cache] [--force]"

    app_list=
    use_default_apps=0
    if [ "$positional_count" -eq 1 ]; then
      ensure_app_name "$pos1"
      [ "$pos1" != "opencode" ] || fail "Refusing to link reserved app name: opencode"
      app_list=$pos1
    else
      app_list=$(default_link_apps)
      use_default_apps=1
    fi

    profiles=$(list_profile_names)
    [ -n "$profiles" ] || fail "No profiles found"

    for profile_name in $profiles; do
      for app_name in $app_list; do
        ensure_app_name "$app_name"
        [ "$app_name" != "opencode" ] || fail "Refusing to link reserved app name: opencode"

        linked_any=0

        if [ "$do_config" = "1" ]; then
          if [ "$use_default_apps" = "1" ] && [ ! -e "$(source_root_for_scope config)/$app_name" ]; then
            :
          else
          link_scope_path "$profile_name" "$app_name" config "$force_link"
            linked_any=1
          fi
        fi
        if [ "$do_data" = "1" ]; then
          if [ "$use_default_apps" = "1" ] && [ ! -e "$(source_root_for_scope data)/$app_name" ]; then
            :
          else
          link_scope_path "$profile_name" "$app_name" data "$force_link"
            linked_any=1
          fi
        fi
        if [ "$do_state" = "1" ]; then
          if [ "$use_default_apps" = "1" ] && [ ! -e "$(source_root_for_scope state)/$app_name" ]; then
            :
          else
          link_scope_path "$profile_name" "$app_name" state "$force_link"
            linked_any=1
          fi
        fi
        if [ "$do_cache" = "1" ]; then
          if [ "$use_default_apps" = "1" ] && [ ! -e "$(source_root_for_scope cache)/$app_name" ]; then
            :
          else
          link_scope_path "$profile_name" "$app_name" cache "$force_link"
            linked_any=1
          fi
        fi

        if [ "$use_default_apps" = "1" ] && [ "$linked_any" = "0" ]; then
          printf 'Skipped default link app %s for profile %s: no source paths found\n' "$app_name" "$profile_name"
        fi
      done
    done

    return 0
  fi

  [ "$positional_count" -eq 2 ] || fail "Usage: ocpersona link <profile> <app> [--no-config] [--no-data] [--no-state] [--no-cache] [--force]"

  profile_name=$pos1
  app_name=$pos2

  ensure_profile_name "$profile_name"
  ensure_app_name "$app_name"
  [ "$app_name" != "opencode" ] || fail "Refusing to link reserved app name: opencode"

  if [ "$do_config" = "1" ]; then
    link_scope_path "$profile_name" "$app_name" config "$force_link"
  fi
  if [ "$do_data" = "1" ]; then
    link_scope_path "$profile_name" "$app_name" data "$force_link"
  fi
  if [ "$do_state" = "1" ]; then
    link_scope_path "$profile_name" "$app_name" state "$force_link"
  fi
  if [ "$do_cache" = "1" ]; then
    link_scope_path "$profile_name" "$app_name" cache "$force_link"
  fi
}

cmd_purge() {
  [ $# -le 1 ] || fail "Usage: ocpersona purge [profile]"

  profile_name=${1:-${OCP_PROFILE:-default}}
  ensure_profile_name "$profile_name"

  profile_root=$(profile_root_for "$profile_name")
  profile_config_home=$(profile_config_home_for "$profile_name")
  profile_data_home=$(profile_data_home_for "$profile_name")
  profile_state_home=$(profile_state_home_for "$profile_name")
  profile_cache_home=$(profile_cache_home_for "$profile_name")

  found_any=0
  for purge_path in \
    "$profile_root" \
    "$profile_config_home" \
    "$profile_data_home" \
    "$profile_state_home" \
    "$profile_cache_home"
  do
    if [ -e "$purge_path" ]; then
      found_any=1
      break
    fi
  done

  if [ "$found_any" -ne 1 ]; then
    printf 'Profile already absent: %s\n' "$profile_name"
    return 0
  fi

  rm -rf \
    "$profile_root" \
    "$profile_config_home" \
    "$profile_data_home" \
    "$profile_state_home" \
    "$profile_cache_home"

  printf 'Purged profile %s\n' "$profile_name"
}

cmd_dump_env() {
  profile_name=${1:-${OCP_PROFILE:-}}
  if [ -z "$profile_name" ]; then
    auto_detect_profile_if_unset
    profile_name=${OCP_PROFILE:-}
    [ -z "$profile_name" ] && fail "No profile specified and OCP_PROFILE is not set"
  fi

  load_profile "$profile_name"

  dump_var OCP_PROFILE
  dump_var OCP_PROFILE_FILE
  dump_var OCP_PATH
  dump_var OCP_SHIM_DIR
  dump_var OCP_CONFIG_DIR
  dump_var OCP_ACTIVE
  [ -n "${OCP_OC_BIN:-}" ] && dump_var OCP_OC_BIN
  dump_var XDG_CONFIG_HOME
  dump_var XDG_DATA_HOME
  dump_var XDG_STATE_HOME
  dump_var XDG_CACHE_HOME
  dump_var PATH
}

cmd_doctor() {
  integration_mode=direct-command
  if [ "${OCP_SHELL_INTEGRATION:-0}" = "1" ]; then
    integration_mode=shell-function
  fi

  current_opencode=$(command -v opencode 2>/dev/null || true)
  active_profile=${OCP_PROFILE:-}
  profile_file=${OCP_PROFILE_FILE:-}
  profile_selected=no
  [ -n "$active_profile" ] && profile_selected=yes
  profile_exists=no
  if [ -n "$profile_file" ] && [ -f "$profile_file" ]; then
    profile_exists=yes
  fi

  profile_oc_bin=
  profile_config_home=
  profile_data_home=
  profile_state_home=
  profile_cache_home=
  if [ "$profile_exists" = "yes" ]; then
    profile_dump=$(PROFILE_FILE="$profile_file" /bin/sh <<'EOF'
set -eu
set -a
. "$PROFILE_FILE"
set +a
printf 'profile_oc_bin=%s\n' "${OCP_OC_BIN:-}"
printf 'profile_config_home=%s\n' "${XDG_CONFIG_HOME:-}"
printf 'profile_data_home=%s\n' "${XDG_DATA_HOME:-}"
printf 'profile_state_home=%s\n' "${XDG_STATE_HOME:-}"
printf 'profile_cache_home=%s\n' "${XDG_CACHE_HOME:-}"
EOF
)
    profile_oc_bin=$(printf '%s\n' "$profile_dump" | sed -n 's/^profile_oc_bin=//p')
    profile_config_home=$(printf '%s\n' "$profile_dump" | sed -n 's/^profile_config_home=//p')
    profile_data_home=$(printf '%s\n' "$profile_dump" | sed -n 's/^profile_data_home=//p')
    profile_state_home=$(printf '%s\n' "$profile_dump" | sed -n 's/^profile_state_home=//p')
    profile_cache_home=$(printf '%s\n' "$profile_dump" | sed -n 's/^profile_cache_home=//p')
  fi

  effective_oc_bin=${OCP_OC_BIN:-}
  if [ -z "$effective_oc_bin" ]; then
    if [ -n "$profile_oc_bin" ]; then
      effective_oc_bin=$profile_oc_bin
    else
      effective_oc_bin=$(default_oc_bin)
    fi
  fi

  runtime_loaded=no
  if [ "${OCP_ACTIVE:-0}" = "1" ]; then
    runtime_loaded=yes
  fi

  effective_config_home=${XDG_CONFIG_HOME:-}
  if [ -z "$effective_config_home" ]; then
    if [ -n "$profile_config_home" ]; then
      effective_config_home=$profile_config_home
    elif [ -n "$active_profile" ]; then
      effective_config_home=$(profile_config_home_for "$active_profile")
    fi
  fi

  effective_data_home=${XDG_DATA_HOME:-}
  if [ -z "$effective_data_home" ]; then
    if [ -n "$profile_data_home" ]; then
      effective_data_home=$profile_data_home
    elif [ -n "$active_profile" ]; then
      effective_data_home=$(profile_data_home_for "$active_profile")
    fi
  fi

  effective_state_home=${XDG_STATE_HOME:-}
  if [ -z "$effective_state_home" ]; then
    if [ -n "$profile_state_home" ]; then
      effective_state_home=$profile_state_home
    elif [ -n "$active_profile" ]; then
      effective_state_home=$(profile_state_home_for "$active_profile")
    fi
  fi

  effective_cache_home=${XDG_CACHE_HOME:-}
  if [ -z "$effective_cache_home" ]; then
    if [ -n "$profile_cache_home" ]; then
      effective_cache_home=$profile_cache_home
    elif [ -n "$active_profile" ]; then
      effective_cache_home=$HOME/.cache/ocpersona/$active_profile
    fi
  fi

  printf 'integration_mode=%s\n' "$integration_mode"
  printf 'opencode_command=%s\n' "${current_opencode:-}"
  printf 'ocpersona_source=%s\n' "$SOURCE_ROOT"
  printf 'ocp_path=%s\n' "${OCP_PATH:-$DEFAULT_OCP_PATH}"
  printf 'ocp_shim_dir=%s\n' "${OCP_SHIM_DIR:-}"
  printf 'ocp_profile=%s\n' "$active_profile"
  printf 'ocp_profile_file=%s\n' "$profile_file"
  printf 'ocp_profile_file_exists=%s\n' "$profile_exists"
  printf 'profile_selected=%s\n' "$profile_selected"
  printf 'profile_runtime_loaded=%s\n' "$runtime_loaded"
  printf 'ocp_config_dir=%s\n' "${OCP_CONFIG_DIR:-$DEFAULT_CONFIG_DIR}"
  printf 'ocp_oc_bin=%s\n' "${OCP_OC_BIN:-}"
  printf 'profile_oc_bin=%s\n' "$profile_oc_bin"
  printf 'profile_config_home=%s\n' "$profile_config_home"
  printf 'effective_config_home=%s\n' "$effective_config_home"
  printf 'effective_oc_bin=%s\n' "$effective_oc_bin"
  printf 'ocp_active=%s\n' "${OCP_ACTIVE:-0}"
  printf 'xdg_config_home=%s\n' "${XDG_CONFIG_HOME:-}"
  printf 'xdg_data_home=%s\n' "${XDG_DATA_HOME:-}"
  printf 'xdg_state_home=%s\n' "${XDG_STATE_HOME:-}"
  printf 'xdg_cache_home=%s\n' "${XDG_CACHE_HOME:-}"
  printf 'profile_data_home=%s\n' "$profile_data_home"
  printf 'profile_state_home=%s\n' "$profile_state_home"
  printf 'profile_cache_home=%s\n' "$profile_cache_home"
  printf 'effective_data_home=%s\n' "$effective_data_home"
  printf 'effective_state_home=%s\n' "$effective_state_home"
  printf 'effective_cache_home=%s\n' "$effective_cache_home"
  starship_config=$(default_starship_config)
  starship_block_installed=no
  if [ -f "$starship_config" ] && grep -Fq "# >>> ocpersona starship >>>" "$starship_config"; then
    starship_block_installed=yes
  fi
  printf 'starship_config=%s\n' "$starship_config"
  printf 'starship_block_installed=%s\n' "$starship_block_installed"
}

cmd_install() {
  [ $# -le 1 ] || fail "Usage: ocpersona install [file]"
  target_file=${1:-$(default_shell_rc)}
  target_dir=$(dirname -- "$target_file")
  install_root=$SOURCE_ROOT
  install_root_value=$install_root
  case "$install_root" in
    "$HOME")
      install_root_value=\$HOME
      ;;
    "$HOME"/*)
      install_root_value=\$HOME${install_root#"$HOME"}
      ;;
  esac
  config_file=$(managed_config_file)
  config_dir=$(dirname -- "$config_file")
  start_marker="# >>> ocpersona >>>"
  end_marker="# <<< ocpersona <<<"
  tmp_file=

  mkdir -p "$target_dir"
  mkdir -p "$config_dir"
  [ -f "$target_file" ] || : > "$target_file"

  cat > "$config_file" <<EOF
if [ -z "\${OCP_PATH:-}" ]; then
  OCP_PATH="${install_root_value}"
fi
if [ -z "\${OCP_DEFAULT_LINK_APPS:-}" ]; then
  OCP_DEFAULT_LINK_APPS="gh vim nvim"
fi
EOF

  remove_managed_block "$target_file" "$start_marker" "$end_marker"

  append_managed_block "$target_file" "$(cat <<EOF
$start_marker
export OCP_PATH="\${OCP_PATH:-${install_root_value}}"
[ -f "\${OCP_PATH}/contrib/ocpersona.plugin.zsh" ] && source "\${OCP_PATH}/contrib/ocpersona.plugin.zsh"
$end_marker
EOF
)"

  printf 'Installed ocpersona init into %s using %s\n' "$target_file" "$install_root"
}

cmd_install_starship() {
  [ $# -le 1 ] || fail "Usage: ocpersona install-starship [file]"
  target_file=${1:-$(default_starship_config)}
  target_dir=$(dirname -- "$target_file")
  start_marker="# >>> ocpersona starship >>>"
  end_marker="# <<< ocpersona starship <<<"

  mkdir -p "$target_dir"
  [ -f "$target_file" ] || : > "$target_file"

  remove_managed_block "$target_file" "$start_marker" "$end_marker"

  append_managed_block "$target_file" "$(cat <<'EOF'
# >>> ocpersona starship >>>
# Shows the active ocpersona profile when OCP_PROFILE is set.
# If you use a custom top-level Starship format that omits $env_var,
# add ${env_var.OCP_PROFILE} or $env_var to that format explicitly.
[env_var.OCP_PROFILE]
variable = "OCP_PROFILE"
format = "[ocp:$env_value]($style) "
style = "bold fg:39"
description = "The active ocpersona profile"
# <<< ocpersona starship <<<
EOF
)"

  printf 'Installed ocpersona Starship config into %s\n' "$target_file"
  printf '%s\n' "If your Starship format omits \$env_var, add \$env_var or \${env_var.OCP_PROFILE} so the profile renders."
}

cmd_init() {
  shell_name=${1:-sh}
  case "$shell_name" in
    zsh|bash|sh) ;;
    *)
      fail "Unsupported shell: $shell_name"
      ;;
  esac

  cat <<EOF
export OCP_PATH="${DEFAULT_OCP_PATH}"
export OCP_SHIM_DIR="\${OCP_PATH}/shims"
export OCP_SHELL_INTEGRATION=1
path_without_shim=
old_ifs=\$IFS
IFS=:
for path_dir in \$PATH; do
  IFS=\$old_ifs
  [ -n "\$path_dir" ] || path_dir=.
  [ "\$path_dir" = "\${OCP_SHIM_DIR}" ] && continue
  if [ -n "\${path_without_shim:-}" ]; then
    path_without_shim=\${path_without_shim}:\$path_dir
  else
    path_without_shim=\$path_dir
  fi
  IFS=:
done
IFS=\$old_ifs
if [ -n "\${path_without_shim:-}" ]; then
  export PATH="\${OCP_SHIM_DIR}:\$path_without_shim"
else
  export PATH="\${OCP_SHIM_DIR}"
fi
unset path_without_shim
unset old_ifs
unset path_dir
if command -v rehash >/dev/null 2>&1; then
  rehash
elif command -v hash >/dev/null 2>&1; then
  hash -r 2>/dev/null || true
fi
ocpersona() {
  case "\${1:-}" in
    activate)
      shift
      eval "\$(command "\${OCP_PATH}/bin/ocpersona" activate "\$@")"
      ;;
    deactivate)
      shift
      eval "\$(command "\${OCP_PATH}/bin/ocpersona" deactivate "\$@")"
      ;;
    *)
      command "\${OCP_PATH}/bin/ocpersona" "\$@"
      ;;
  esac
}
opencode() {
  if [ "\${OCP_PROFILE:-}" != "" ] && [ "\${OCP_ACTIVE:-0}" != "1" ]; then
    "\${OCP_PATH}/bin/ocpersona" exec "\$OCP_PROFILE" -- "\${OCP_PATH}/bin/ocpersona" __run_real_opencode "\$@"
  else
    "\${OCP_SHIM_DIR}/opencode" "\$@"
  fi
}
EOF
}

cmd_run_real_opencode() {
  oc_bin=${OCP_OC_BIN:-}
  if [ -z "$oc_bin" ]; then
    oc_bin=$(default_oc_bin)
  fi
  exec "$oc_bin" "$@"
}

cmd_shim_opencode() {
  if [ "${OCP_PROFILE:-}" != "" ] && [ "${OCP_ACTIVE:-0}" != "1" ]; then
    exec "$SOURCE_ROOT/bin/ocpersona" exec "$OCP_PROFILE" -- "$SOURCE_ROOT/bin/ocpersona" __run_real_opencode "$@"
  fi

  cmd_run_real_opencode "$@"
}

main() {
  _pre_autodetect_profile=${OCP_PROFILE:-}
  auto_detect_profile_if_unset

  command_name=${1:-help}
  case "$command_name" in
    list)
      shift
      cmd_list "$@"
      ;;
    exec)
      shift
      cmd_exec "$@"
      ;;
    activate)
      shift
      cmd_activate "$@"
      ;;
    clone)
      shift
      cmd_clone "$@"
      ;;
    deactivate)
      shift
      cmd_deactivate "$@"
      ;;
    link)
      shift
      cmd_link "$@"
      ;;
    clone-default)
      shift
      cmd_clone_default "$@"
      ;;
    purge)
      shift
      cmd_purge "$@"
      ;;
    doctor)
      shift
      cmd_doctor "$@"
      ;;
    dump-env)
      shift
      cmd_dump_env "$@"
      ;;
    install)
      shift
      cmd_install "$@"
      ;;
    install-starship)
      shift
      cmd_install_starship "$@"
      ;;
    init)
      shift
      cmd_init "$@"
      ;;
    __shim_opencode)
      shift
      cmd_shim_opencode "$@"
      ;;
    __run_real_opencode)
      shift
      cmd_run_real_opencode "$@"
      ;;
    help|-h|--help)
      usage
      ;;
    *)
      fail "Unknown command: $command_name"
      ;;
  esac
}

main "$@"
