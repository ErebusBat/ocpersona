# Example ocpersona profile.
#
# Copy this to:
#   ~/.config/ocpersona/profiles/<profile>/ocpersona.sh
#
# Then customize it for the selected profile.

# Keep the profile self-contained by default.
profile_dir="${OCP_PROFILE_FILE%/*}"
XDG_CONFIG_HOME="${profile_dir}/config"
XDG_DATA_HOME="${profile_dir}/data"
XDG_STATE_HOME="${profile_dir}/state"

OCP_OC_BIN=/opt/homebrew/Cellar/opencode/1.14.28/bin/opencode

# Cache can stay outside the profile directory if you want.
XDG_CACHE_HOME="$HOME/.cache/opencode-example"
